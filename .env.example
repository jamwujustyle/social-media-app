# ──────────────────────────────────────────────
# Users API — Environment Configuration Template
# ──────────────────────────────────────────────
# Copy this file to .env:  cp .env.example .env
# Or run:                   just setup
#
# NEVER commit .env to version control.
# In production, inject secrets via CI/CD (GitHub Secrets, Vault, AWS SSM, etc.)
# ──────────────────────────────────────────────

# ── Application ────────────────────────────────
# Set to false in production to disable debug routes and Swagger UI
DEBUG=true

# ── PostgreSQL ────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=users_db

# ── JWT Security ──────────────────────────────
# Generate a strong key: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Redis / Celery ────────────────────────────
REDIS_URL=redis://redis:6379/0
